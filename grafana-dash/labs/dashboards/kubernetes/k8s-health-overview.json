                  "unit": "s"
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-8": {
        "kind": "Panel",
        "spec": {
          "id": 8,
          "title": "Write Availability (30d)",
          "description": "How many percent of write requests (POST|PUT|PATCH|DELETE) in 30 days have been answered successfully and fast enough?",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "expr": "apiserver_request:availability30d{verb=\"write\", cluster=\"$cluster\"}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {
                "interval": "1m"
              }
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "stat",
            "version": "v11.4.0",
            "spec": {
              "options": {},
              "fieldConfig": {
                "defaults": {
                  "unit": "percentunit",
                  "decimals": 3
                },
                "overrides": []
              }
            }
          }
        }
      },
      "panel-9": {
        "kind": "Panel",
        "spec": {
          "id": 9,
          "title": "Write SLI - Requests",
          "description": "How many write requests (POST|PUT|PATCH|DELETE) per second do the apiservers get by code?",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "expr": "sum by (code) (code_resource:apiserver_request_total:rate5m{verb=\"write\", cluster=\"$cluster\"})",
                        "legendFormat": "{{ code }}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {
                "interval": "1m"
              }
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "v11.4.0",
            "spec": {
              "options": {
                "legend": {
                  "asTable": true,
                  "placement": "right",
                  "showLegend": true
                },
                "tooltip": {
                  "mode": "single"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "reqps",
                  "custom": {
                    "fillOpacity": 100,
                    "stacking": {
                      "mode": "normal"
                    }
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "/2../i"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": "#56A64B"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "/3../i"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": "#F2CC0C"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "/4../i"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": "#3274D9"
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "/5../i"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": "#E02F44"
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      }
